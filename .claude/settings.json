{
  "permissions": {
    "allow": [
      "Bash(bundle exec jekyll build)",
      "Bash(bundle exec jekyll serve *)",
      "Bash(bundle exec rake *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(node scripts/geocode-maps.js)",
      "Bash(bash scripts/check-responsive-policy.sh)",
      "Bash(python3 scripts/check-single-use-variables.py *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(stat *)",
      "Bash(jq *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Read(*)"
    ],
    "deny": [
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Read(./_site/**)",
      "Read(_site/**)",
      "Read(./node_modules/**)",
      "Read(node_modules/**)",
      "Read(./.sass-cache/**)",
      "Read(.sass-cache/**)",
      "Read(./assets/js/main.min.js)",
      "Read(assets/js/main.min.js)",
      "Read(./assets/js/vendor/**)",
      "Read(assets/js/vendor/**)",
      "Read(./assets/maps/*.geojson)",
      "Read(assets/maps/*.geojson)",
      "Read(./package-lock.json)",
      "Read(./Gemfile.lock)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-tool-edit-nudges.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/post-tool-variables-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/stop-variables-check.sh"
          }
        ]
      }
    ]
  }
}
